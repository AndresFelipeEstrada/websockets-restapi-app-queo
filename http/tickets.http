@baseUrl = http://localhost:3000/api
@tickets = {{baseUrl}}/tickets
@contentType = application/json

### All Tickets
GET {{tickets}}/ HTTP/1.1
Content-Type: {{contentType}}

### Last ticket
GET {{tickets}}/last HTTP/1.1
Content-Type: {{contentType}}

### Pending ticket
GET {{tickets}}/pending HTTP/1.1
Content-Type: {{contentType}}

### Create ticket
POST {{tickets}} HTTP/1.1
Content-Type: {{contentType}}
